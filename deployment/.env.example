# CareerStack API Server - Production Environment Template
# Copy this file to .env.production and fill in your actual values

# Database Configuration
# Format: mysql2://username:password@host:port/database
DATABASE_URL=mysql2://careerstack:YOUR_DB_PASSWORD@localhost:3306/careerstack

# Clerk Authentication (from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_live_YOUR_CLERK_SECRET
CLERK_PUBLISHABLE_KEY=pk_live_YOUR_CLERK_PUBLIC

# Server Configuration  
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Development Overrides (set to false for production)
SKIP_ADMIN_CHECK=false
